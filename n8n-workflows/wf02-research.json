    {
      "parameters": {
        "jsCode": "const raw = $input.item.json.output;\nconst cleaned = raw.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\nconst parsed = JSON.parse(cleaned);\n\nconst webhookBody = $('Webhook').first().json.body;\nconst dbRow = $('Get a row').first().json || {};\n\nlet req = webhookBody.requirements_json || dbRow.requirements_json || {};\nif (typeof req === 'string') {\n  try { req = JSON.parse(req); } catch(e) { req = {}; }\n}\n\nconst brief = parsed.research_brief || {};\nconst findings = (brief.key_findings || []).slice(0, 4).map(function(f) { return '• ' + f.finding; }).join('\\n');\nconst recs = (brief.strategic_recommendations || []).slice(0, 3).map(function(r) { return '• ' + r; }).join('\\n');\nconst risks = (brief.risks_and_considerations || []).slice(0, 2).map(function(r) { return '• ' + r; }).join('\\n');\n\nconst research_preview = ('*Market Context:*\\n' + (brief.market_context || '') +\n  '\\n\\n*Key Findings:*\\n' + findings +\n  '\\n\\n*Strategic Recommendations:*\\n' + recs +\n  '\\n\\n*Risks:*\\n' + risks).slice(0, 2500);\n\nreturn {\n  json: {\n    research_brief: parsed.research_brief,\n    research_preview: research_preview,\n    engagement_id: webhookBody.engagement_id,\n    requirements: req\n  }\n};"
      },
