    {
      "parameters": {
        "jsCode": "const webhookBody = $('Webhook').first().json.body;\nconst dbRow = $('Get a row').first().json || {};\n\nlet req = webhookBody.requirements_json || dbRow.requirements_json || {};\nif (typeof req === 'string') {\n  try { req = JSON.parse(req); } catch(e) { req = {}; }\n}\n\nconst engagementId = webhookBody.engagement_id;\nconst revision_notes = webhookBody.revision_notes || dbRow.revision_notes || '';\nconst keyQs = req.key_questions ? req.key_questions.join(' | ') : '';\n\nlet agentInput = \"You are researching for a consulting engagement. Here are the details:\\n\\n\" +\n  \"Client: \" + (req.client_name || webhookBody.client_name || '') + \"\\n\" +\n  \"Industry: \" + (req.industry || '') + \"\\n\" +\n  \"Deck Type: \" + (req.deck_type || webhookBody.deck_type || '') + \"\\n\" +\n  \"Engagement Goal: \" + (req.engagement_goal || '') + \"\\n\" +\n  \"Key Questions: \" + keyQs + \"\\n\" +\n  \"Timeline: \" + (req.timeline || '') + \"\\n\" +\n  \"Constraints: \" + (req.constraints || '') + \"\\n\" +\n  \"Search Query: \" + (req.rag_search_query || '') + \"\\n\\n\";\n\nif (revision_notes) {\n  agentInput += \"\\u26a0\\ufe0f REVISION FEEDBACK \\u2014 incorporate this into the research: \" + revision_notes + \"\\n\\n\";\n}\n\nagentInput += \"Use the knowledge base tool to search for relevant consulting frameworks and insights. Then output ONLY this JSON, no markdown:\\n\\n\" +\n  \"{\\n\" +\n  \"  \\\"research_brief\\\": {\\n\" +\n  \"    \\\"market_context\\\": \\\"2-3 sentence market summary\\\",\\n\" +\n  \"    \\\"key_findings\\\": [{\\\"finding\\\": \\\"insight\\\", \\\"source\\\": \\\"source\\\", \\\"confidence\\\": \\\"high\\\"}],\\n\" +\n  \"    \\\"strategic_recommendations\\\": [\\\"rec 1\\\", \\\"rec 2\\\", \\\"rec 3\\\"],\\n\" +\n  \"    \\\"risks_and_considerations\\\": [\\\"risk 1\\\", \\\"risk 2\\\"],\\n\" +\n  \"    \\\"knowledge_base_hits\\\": 3,\\n\" +\n  \"    \\\"ready_for_storyline\\\": true\\n\" +\n  \"  }\\n\" +\n  \"}\";\n\nreturn {\n  json: {\n    agent_input: agentInput,\n    engagement_id: engagementId,\n    requirements: req,\n    revision_notes: revision_notes\n  }\n};"
      },
